{
    "name": "sandermuller/project-boost",
    "description": "AI agent skills for PHP application developers. Patterns, conventions, and guidance for non-package projects.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "sandermuller",
        "project-boost",
        "ai",
        "claude",
        "cursor",
        "php",
        "applications",
        "developer-tools"
    ],
    "homepage": "https://github.com/sandermuller/project-boost",
    "authors": [
        {
            "name": "Sander Muller",
            "email": "github@scode.nl",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "sandermuller/boost-core": "^0.7.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "sandermuller/boost-skills": "^1.1",
        "sandermuller/package-boost-php": "^0.8",
        "stolt/lean-package-validator": "^5.9"
    },
    "autoload-dev": {
        "psr-4": {
            "SanderMuller\\ProjectBoost\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "SanderMuller\\BoostCore\\Scripts\\BoostAutoSync::run"
        ],
        "post-update-cmd": [
            "SanderMuller\\BoostCore\\Scripts\\BoostAutoSync::run"
        ],
        "format": "vendor/bin/pint",
        "format-check": "vendor/bin/pint --test",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "sync-ai": [
            "SanderMuller\\BoostCore\\Scripts\\BoostAutoSync::runWithSummary"
        ],
        "validate-gitattributes": "vendor/bin/lean-package-validator validate",
        "qa": [
            "@format",
            "@validate-gitattributes",
            "@test"
        ],
        "ci": [
            "@validate-gitattributes",
            "@test"
        ],
        "qa-check": [
            "vendor/bin/pint --test",
            "@validate-gitattributes"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "sandermuller/package-boost-php": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
