{
    "name": "sandermuller/project-boost",
    "description": "AI agent skills for PHP application developers. Patterns, conventions, and guidance for non-package projects.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "sandermuller",
        "project-boost",
        "ai",
        "claude",
        "cursor",
        "php",
        "applications",
        "developer-tools"
    ],
    "homepage": "https://github.com/sandermuller/project-boost",
    "authors": [
        {
            "name": "Sander Muller",
            "email": "github@scode.nl",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "sandermuller/boost-core": "^0.3.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "stolt/lean-package-validator": "^5.9"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        },
        "boost": {
            "skills": "resources/boost/skills",
            "guidelines": "resources/boost/guidelines"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SanderMuller\\ProjectBoost\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "if [ \"$COMPOSER_DEV_MODE\" = \"1\" ]; then vendor/bin/boost sync 2>/dev/null || true; fi"
        ],
        "post-update-cmd": [
            "@post-install-cmd"
        ],
        "format": "vendor/bin/pint",
        "format-check": "vendor/bin/pint --test",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "sync-ai": "vendor/bin/boost sync",
        "validate-gitattributes": "vendor/bin/lean-package-validator validate",
        "qa": [
            "@format",
            "@validate-gitattributes",
            "@test"
        ],
        "ci": [
            "@validate-gitattributes",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "sandermuller/boost-core": true
        }
    },
    "prefer-stable": true
}
